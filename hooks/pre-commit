#!/bin/sh
# Locveil pre-commit hook (../locveil-commons/process/ledger-discipline.md §4 +
# process/contracts.md §4): scope-guard + contract-guard checks only — hooks never
# mutate the tree. Install once:  git config core.hooksPath hooks
python3 scripts/scope_guard.py --config .scope-guard.toml --check || exit 1
exec python3 scripts/contract_guard.py --check
