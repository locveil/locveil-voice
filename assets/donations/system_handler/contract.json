{
  "$schema": "../../donation_contract_v1.1.json",
  "schema_version": "1.1",
  "donation_version": "1.1.0",
  "handler_domain": "system",
  "intent_name_patterns": [
    "system.status",
    "system.help",
    "system.version",
    "system.info"
  ],
  "domain_patterns": [
    "system"
  ],
  "method_donations": [
    {
      "method_name": "_handle_help_request",
      "intent_suffix": "help",
      "boost": 1.3,
      "room_context": "none",
      "parameters": [
        {
          "name": "topic",
          "type": "string",
          "required": false,
          "entity_type": "generic"
        }
      ]
    },
    {
      "method_name": "_handle_status_request",
      "intent_suffix": "status",
      "boost": 1.2,
      "room_context": "none",
      "parameters": [
        {
          "name": "component",
          "type": "string",
          "required": false,
          "entity_type": "generic"
        }
      ]
    },
    {
      "method_name": "_handle_version_request",
      "intent_suffix": "version",
      "boost": 1.1,
      "room_context": "none",
      "parameters": []
    },
    {
      "method_name": "_handle_info_request",
      "intent_suffix": "info",
      "boost": 1.0,
      "room_context": "none",
      "parameters": [
        {
          "name": "info_type",
          "type": "choice",
          "required": false,
          "choices": [
            "system",
            "performance"
          ],
          "entity_type": "generic"
        }
      ]
    },
    {
      "method_name": "_handle_general_info",
      "intent_suffix": "about",
      "boost": 1.1,
      "room_context": "none",
      "parameters": []
    }
  ],
  "global_parameters": [
    {
      "name": "language",
      "type": "choice",
      "required": false,
      "choices": [
        "ru",
        "en"
      ],
      "entity_type": "generic"
    }
  ]
}
