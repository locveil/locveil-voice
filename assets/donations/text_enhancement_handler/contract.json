{
  "$schema": "../../donation_contract_v1.1.json",
  "schema_version": "1.1",
  "donation_version": "1.1.0",
  "handler_domain": "text_enhancement",
  "intent_name_patterns": [
    "text.enhance",
    "text.improve",
    "text.correct",
    "llm.enhance"
  ],
  "domain_patterns": [
    "text",
    "enhancement",
    "improvement",
    "llm"
  ],
  "method_donations": [
    {
      "method_name": "_handle_enhance_text",
      "intent_suffix": "enhance",
      "boost": 1.3,
      "room_context": "none",
      "parameters": [
        {
          "name": "text",
          "type": "string",
          "required": false,
          "entity_type": "generic"
        }
      ]
    },
    {
      "method_name": "_handle_improve_text",
      "intent_suffix": "improve",
      "boost": 1.4,
      "room_context": "none",
      "parameters": [
        {
          "name": "text",
          "type": "string",
          "required": false,
          "entity_type": "generic"
        },
        {
          "name": "improvement_type",
          "type": "choice",
          "required": false,
          "choices": [
            "grammar",
            "style",
            "clarity",
            "general",
            "vocabulary"
          ],
          "entity_type": "generic"
        }
      ]
    },
    {
      "method_name": "_handle_correct_text",
      "intent_suffix": "correct",
      "boost": 1.2,
      "room_context": "none",
      "parameters": [
        {
          "name": "text",
          "type": "string",
          "required": false,
          "entity_type": "generic"
        },
        {
          "name": "correction_type",
          "type": "choice",
          "required": false,
          "choices": [
            "grammar",
            "spelling",
            "punctuation",
            "style",
            "all"
          ],
          "entity_type": "generic"
        }
      ]
    }
  ],
  "global_parameters": [
    {
      "name": "language",
      "type": "choice",
      "required": false,
      "choices": [
        "ru",
        "en"
      ],
      "entity_type": "generic"
    }
  ]
}
