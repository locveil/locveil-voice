// What spaCy does, on one sentence. Render:
//   dot -Tpng docs/images/spacy-explainer.dot -o docs/images/spacy-explainer.png
digraph spacy {
  rankdir=LR; bgcolor="white"; splines=spline; nodesep=0.3; ranksep=0.7;
  fontname="Helvetica"; labelloc=t; fontsize=15;
  label="What spaCy does: turn a sentence into structure a machine can reason about";
  node [fontname="Helvetica", fontsize=10, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#9e9e9e", arrowsize=0.7];

  sent [label="“set a timer for five minutes”", fillcolor="#fff8e1", color="#f9a825", fontsize=12];

  subgraph cluster_spacy {
    label="spaCy language model (one per language)"; fontsize=12; color="#ce93d8"; style=rounded; margin=12;
    node [fillcolor="#f3e5f5", color="#7b1fa2"];
    tok [label="tokenise\nset · a · timer · for · five · minutes"];
    pos [label="tag part of speech\nVERB · DET · NOUN · ADP · NUM · NOUN"];
    lem [label="lemmatise (base forms)\nminutes → minute"];
    ner [label="find entities\n“five minutes” → DURATION"];
    tok -> pos -> lem -> ner;
  }

  result [label="structure Irene matches on:\ntokens · lemmas · part-of-speech · entities", fillcolor="#e8f5e8", color="#388e3c"];

  sent -> tok;
  ner -> result;
}
