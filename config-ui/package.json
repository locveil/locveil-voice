{
  "name": "irene-donation-editor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "check:orphans": "node scripts/find-orphans.mjs",
    "test": "vitest run",
    "check": "npm run type-check && npm run lint && npm run check:orphans",
    "gen:api-types": "openapi-typescript ./openapi.json -o ./src/types/openapi.gen.ts && json2ts -i ../assets/donation_contract_v1.1.json -o ./src/types/donation-contract.gen.ts --additionalProperties false && json2ts -i ../assets/donation_language_v1.1.json -o ./src/types/donation-language.gen.ts --additionalProperties false"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "i18next": "^23.16.8",
    "locveil-ui-kit": "file:../../locveil-commons/packages/ui-kit",
    "lucide-react": "^0.453.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.5.0",
    "react-router-dom": "^6.30.4",
    "react-syntax-highlighter": "^16.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^20.5.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "json-schema-to-typescript": "^15.0.4",
    "locveil-workbench": "file:../../locveil-commons/packages/workbench",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.9",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
