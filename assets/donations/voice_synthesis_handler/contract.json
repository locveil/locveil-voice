{
  "$schema": "../../donation_contract_v1.1.json",
  "schema_version": "1.1",
  "donation_version": "1.1.0",
  "handler_domain": "voice_synthesis",
  "intent_name_patterns": [
    "tts.speak",
    "tts.voice",
    "tts.list",
    "tts.switch",
    "voice_synthesis.stop",
    "voice_synthesis.cancel",
    "voice.synthesis"
  ],
  "domain_patterns": [
    "tts",
    "voice",
    "speech",
    "synthesis"
  ],
  "action_domain_priority": 60,
  "method_donations": [
    {
      "method_name": "_handle_speak_with_voice",
      "intent_suffix": "voice",
      "boost": 1.4,
      "room_context": "none",
      "parameters": [
        {
          "name": "text",
          "type": "string",
          "required": false,
          "entity_type": "generic"
        },
        {
          "name": "voice",
          "type": "choice",
          "required": false,
          "choices": [
            "xenia",
            "aidar",
            "silero",
            "console",
            "system"
          ],
          "entity_type": "generic"
        }
      ]
    },
    {
      "method_name": "_handle_list_voices",
      "intent_suffix": "list",
      "boost": 1.2,
      "room_context": "none",
      "parameters": []
    },
    {
      "method_name": "_handle_speak_text",
      "intent_suffix": "speak",
      "boost": 1.3,
      "room_context": "none",
      "parameters": [
        {
          "name": "text",
          "type": "string",
          "required": true,
          "entity_type": "generic"
        }
      ]
    },
    {
      "method_name": "_handle_switch_tts_provider",
      "intent_suffix": "switch",
      "boost": 1.1,
      "room_context": "none",
      "parameters": [
        {
          "name": "provider",
          "type": "choice",
          "required": true,
          "choices": [
            "silero",
            "silero3",
            "silero4",
            "console",
            "system",
            "vosk"
          ],
          "entity_type": "generic"
        }
      ]
    },
    {
      "method_name": "_handle_stop_synthesis",
      "intent_suffix": "stop",
      "boost": 1.2,
      "room_context": "none",
      "parameters": []
    },
    {
      "method_name": "_handle_cancel_synthesis",
      "intent_suffix": "cancel",
      "boost": 1.2,
      "room_context": "none",
      "parameters": []
    }
  ],
  "global_parameters": [
    {
      "name": "language",
      "type": "choice",
      "required": false,
      "choices": [
        "ru",
        "en"
      ],
      "entity_type": "generic"
    }
  ]
}
