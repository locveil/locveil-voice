# Machine-local microphone config for the fixture recorder (`make record`).
# Copy to `recording.env` (git-ignored) and adjust for THIS machine — the real file is never committed.
# Discover your input device with:  make record-devices
#
# Consumed by eval-commons' eval-fixture-record (logic is shared; this data is per-machine).

# Input device: a NAME substring (preferred — indices shift between boots) or a numeric index.
# Blank = system default input.
REC_INPUT_DEVICE=

# Capture sample rate. 16000 records natively at the wire rate (no resampling — best fidelity).
# If your mic can't do 16k, set its native rate (e.g. 48000) and the recorder downsamples on save.
REC_CAPTURE_RATE=16000

# Capture channels. 1 if the mic is mono; >1 is downmixed to mono when saved.
REC_CAPTURE_CHANNELS=1

# Seconds of countdown before recording starts.
REC_COUNTDOWN_S=1
