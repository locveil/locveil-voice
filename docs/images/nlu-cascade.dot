// Irene — the NLU cascade: cheap first, clever when needed. Render:
//   dot -Tpng docs/images/nlu-cascade.dot -o docs/images/nlu-cascade.png
digraph cascade {
  rankdir=LR; bgcolor="white"; splines=spline; nodesep=0.4; ranksep=0.85;
  fontname="Helvetica"; labelloc=t; fontsize=15;
  label="Recognition is a cascade: a cheap keyword match first, spaCy next,\nand — if switched on — a language model, before falling back to chat";
  node [fontname="Helvetica", fontsize=11, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#616161", arrowsize=0.7];

  utt   [label="utterance\n(recognised text)", fillcolor="#fff8e1", color="#f9a825"];
  kw    [label="keyword matcher\ndonation phrases +\nfuzzy match (rapidfuzz)\n— fast, ~ms", fillcolor="#f3e5f5", color="#7b1fa2"];
  spacy [label="spaCy provider\nlanguage model +\npatterns + entities\n— for the hard cases", fillcolor="#f3e5f5", color="#7b1fa2"];
  llm   [label="language model (optional)\nmatch one of the known\ncommands — only when\nswitched on", fillcolor="#f3e5f5", color="#7b1fa2", style="filled,rounded,dashed"];
  fb    [label="fallback\nconversation.general\n(chat / LLM)", fillcolor="#e3f2fd", color="#1976d2"];
  out   [label="Intent\nname · entities · confidence", fillcolor="#e8f5e8", color="#388e3c"];

  utt -> kw;
  kw    -> out [label="confident (≥ 0.7)"];
  kw    -> spacy [label="not sure", style=dashed, color="#9e9e9e"];
  spacy -> out [label="confident"];
  spacy -> llm [label="still not sure", style=dashed, color="#9e9e9e"];
  llm   -> out [label="confident"];
  llm   -> fb  [label="no match", style=dashed, color="#9e9e9e"];
  fb    -> out;
}
