// Irene — smart-home deployment + pairing (planned). Render:
//   dot -Tpng docs/images/mqtt-deployment.dot -o docs/images/mqtt-deployment.png
digraph deploy {
  rankdir=LR; bgcolor="white"; splines=spline; nodesep=0.45; ranksep=1.0;
  fontname="Helvetica"; labelloc=t; fontsize=15;
  label="PLANNED — one bridge owns the devices; Irene pairs with it the same way wherever it runs";
  node [fontname="Helvetica", fontsize=10, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#616161", arrowsize=0.7];

  // deployment contexts (where Irene runs)
  subgraph cluster_irene {
    label="Irene (offline smart assistant)"; fontsize=12; color="#a5d6a7"; style=rounded; margin=12;
    wb     [label="on a Wirenboard\ncontroller", fillcolor="#e8f5e8", color="#388e3c"];
    stand  [label="standalone\n(its own box)", fillcolor="#e8f5e8", color="#388e3c"];
  }

  bridge [label="wb-mqtt-bridge\nthe single device authority", fillcolor="#e3f2fd", color="#1976d2"];

  subgraph cluster_gear {
    label="devices (the bridge's problem, not Irene's)"; fontsize=12; color="#ce93d8"; style=rounded; margin=12;
    native [label="native WB gear\n(wb-rules)", fillcolor="#f3e5f5", color="#7b1fa2"];
    av     [label="AV equipment", fillcolor="#f3e5f5", color="#7b1fa2"];
    later  [label="others, later", fillcolor="#f5f5f5", color="#9e9e9e"];
  }

  wb    -> bridge [label="canonical commands\n+ catalog pull"];
  stand -> bridge [label="canonical commands\n+ catalog pull"];
  bridge -> native;
  bridge -> av;
  bridge -> later [style=dashed, color="#9e9e9e"];
}
