{
  "repo": "locveil-voice",
  "roots": ["README.md", "CONTRIBUTING.md", "docs/QUICKSTART.md", "docs/guides",
            "docs/architecture", "docs/images", "ops/INSTALL.md", "eval/README.md"],
  "surfaces": {
    "ws-protocol": ["irene/runners/webapi_router.py", "irene/satellite/**", "irene/core/ws_protocol.py", "contracts/ws-protocol/**"],
    "rest-api": ["irene/components/**", "config-ui/openapi.json", "scripts/dump_openapi.py"],
    "config": ["irene/config/**", "configs/**"],
    "donations": ["assets/donations/**", "assets/donation_*.json"],
    "providers": ["irene/providers/**", "contracts/wake-pack/**"],
    "intents": ["irene/intents/**", "irene/core/intent_*.py"],
    "smart-home": ["irene/intents/device_commands.py", "contracts/pins/catalog/**"],
    "deployment": ["docker/**", "ops/**", "pyproject.toml"],
    "reports": ["irene/core/report_*.py", "contracts/pins/report-protocol/**"],
    "eval": ["eval/**"]
  },
  "nodes": [
    { "id": "readme", "path": "README.md", "class": "front-door",
      "audience": ["end-user", "operator", "contributor"], "status": "ok" },
    { "id": "contributing", "path": "CONTRIBUTING.md", "class": "contributor",
      "audience": ["contributor"], "status": "ok" },
    { "id": "quickstart", "path": "docs/QUICKSTART.md", "class": "quickstart",
      "audience": ["operator", "tester"], "covers": ["config", "deployment"], "status": "ok" },
    { "id": "install", "path": "ops/INSTALL.md", "class": "operator",
      "audience": ["operator"], "covers": ["deployment"], "status": "ok" },
    { "id": "eval/readme", "path": "eval/README.md", "class": "howto",
      "audience": ["tester", "contributor"], "covers": ["eval"], "status": "ok" },

    { "id": "guides/asset-management", "path": "docs/guides/asset-management.md", "class": "howto",
      "audience": ["operator"], "covers": ["providers", "config"], "status": "ok" },
    { "id": "guides/audio", "path": "docs/guides/audio.md", "class": "howto",
      "audience": ["operator"], "covers": ["providers", "config"], "status": "ok" },
