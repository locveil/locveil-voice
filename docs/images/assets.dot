// Irene — asset management: declared, fetched on demand, all under one root. Render:
//   dot -Tpng docs/images/assets.dot -o docs/images/assets.png
digraph assets {
  rankdir=LR; bgcolor="white"; splines=spline; nodesep=0.4; ranksep=1.0;
  fontname="Helvetica"; labelloc=t; fontsize=15;
  label="Assets are declared by providers, fetched on demand, and kept under one root";
  node [fontname="Helvetica", fontsize=10, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#616161", arrowsize=0.7];

  prov [label="provider / component\ndeclares get_asset_config:\nmodel URLs · directory ·\ncredentials · cache", fillcolor="#e8f5e8", color="#388e3c"];
  mgr  [label="AssetManager\nensure_model_available\n→ download once if missing", fillcolor="#e3f2fd", color="#1976d2"];

  url [label="model source\nGitHub release / HuggingFace", fillcolor="#eeeeee", color="#9e9e9e"];
  env [label="env / .env\nAPI keys · service accounts", fillcolor="#eeeeee", color="#9e9e9e"];

  subgraph cluster_root {
    label="assets root   (IRENE_ASSETS_ROOT, default ~/.cache/irene)"; fontsize=12; color="#90caf9"; style=rounded; margin=14;
    models [label="models/\nASR · TTS · LLM\nwake word · spaCy · VAD", fillcolor="#f3e5f5", color="#7b1fa2"];
    cache  [label="cache/\nrecognition results,\nprocessed data (TTL)", fillcolor="#f3e5f5", color="#7b1fa2"];
    creds  [label="credentials/\ncloud secrets", fillcolor="#f3e5f5", color="#7b1fa2"];
  }

  prov -> mgr [label="needs a model"];
  url  -> mgr [label="download + extract", color="#9e9e9e"];
  mgr  -> models [label="cache once"];
  env  -> creds [color="#9e9e9e"];
  prov -> cache [label="read / write at runtime", style=dashed, dir=both, color="#7b1fa2"];

  warm [shape=note, fillcolor="#fffde7", color="#fbc02d", fontsize=9,
        label="At startup, configured providers warm up:\npreload their models so the first request isn't slow."];
  { rank=sink; warm; }
}
