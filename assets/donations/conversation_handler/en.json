{
  "$schema": "../../donation_language_v1.1.json",
  "schema_version": "1.1",
  "handler_domain": "conversation",
  "language": "en",
  "description": "General conversation and reference queries with context management",
  "action_patterns": [
    "start",
    "end",
    "clear",
    "reference"
  ],
  "negative_patterns": [
    [
      {
        "LEMMA": {
          "IN": []
        }
      },
      {
        "LEMMA": {
          "IN": []
        }
      }
    ],
    [
      {
        "TEXT": {
          "REGEX": "no|not|stop"
        }
      },
      {
        "TEXT": {
          "REGEX": "talking|conversation"
        }
      }
    ]
  ],
  "method_donations": [
    {
      "method_name": "_handle_start_conversation",
      "intent_suffix": "start",
      "description": "Start a new conversation or chat session",
      "phrases": [
        "let's talk",
        "let's chat",
        "let's have a conversation",
        "I want to chat with you"
      ],
      "lemmas": [],
      "token_patterns": [
        [
          {
            "TEXT": "let's"
          },
          {
            "TEXT": {
              "REGEX": "talk|chat"
            }
          }
        ],
        [
          {
            "TEXT": "I"
          },
          {
            "TEXT": "want"
          },
          {
            "TEXT": "to"
          },
          {
            "TEXT": {
              "REGEX": "chat|talk"
            }
          }
        ]
      ],
      "slot_patterns": {
        "TOPIC": [
          [
            {
              "LOWER": {
                "IN": []
              }
            },
            {
              "IS_ALPHA": true,
              "OP": "+"
            }
          ],
          [
            {
              "LOWER": "about"
            },
            {
              "IS_ALPHA": true,
              "OP": "+"
            }
          ]
        ]
      },
      "examples": [
        {
          "text": "let's chat",
          "parameters": {}
        },
        {
          "text": "let's talk about music",
          "parameters": {}
        }
      ],
      "parameters": []
    },
    {
      "method_name": "_handle_end_conversation",
      "intent_suffix": "end",
      "description": "End the current conversation",
      "phrases": [
        "stop talking",
        "end conversation",
        "that's enough"
      ],
      "lemmas": [],
      "token_patterns": [
        [
          {
            "TEXT": {
              "REGEX": "stop|end"
            }
          },
          {
            "TEXT": {
              "REGEX": "talking|conversation"
            }
          }
        ]
      ],
      "examples": [
        {
          "text": "stop talking",
          "parameters": {}
        }
      ]
    },
    {
      "method_name": "_handle_clear_conversation",
      "intent_suffix": "clear",
      "description": "Clear conversation history",
      "phrases": [
        "clear history",
        "reset context",
        "forget everything"
      ],
      "lemmas": [],
      "token_patterns": [
        [
          {
            "TEXT": {
              "REGEX": "clear|reset"
            }
          },
          {
            "TEXT": {
              "REGEX": "history|context"
            }
          }
        ]
      ],
      "examples": [
        {
          "text": "clear history",
          "parameters": {}
        }
      ]
    },
    {
      "method_name": "_handle_reference_query",
      "intent_suffix": "reference",
      "description": "Handle reference questions and information requests",
      "phrases": [
        "what is",
        "who is",
        "tell me about",
        "explain this to me"
      ],
      "lemmas": [],
      "token_patterns": [
        [
          {
            "TEXT": {
              "REGEX": "what|who"
            }
          },
          {
            "TEXT": "is"
          }
        ],
        [
          {
            "TEXT": "tell"
          },
          {
            "TEXT": "me"
          },
          {
            "TEXT": "about"
          }
        ]
      ],
      "slot_patterns": {
        "QUERY_TOPIC": [
          [
            {
              "LEMMA": {
                "IN": []
              }
            },
            {
              "LEMMA": "such"
            },
            {
              "IS_ALPHA": true,
              "OP": "+"
            }
          ],
          [
            {
              "TEXT": {
                "REGEX": "what|who"
              }
            },
            {
              "TEXT": "is"
            },
            {
              "IS_ALPHA": true,
              "OP": "+"
            }
          ],
          [
            {
              "LEMMA": "tell"
            },
            {
              "LEMMA": "about"
            },
            {
              "IS_ALPHA": true,
              "OP": "+"
            }
          ]
        ]
      },
      "examples": [
        {
          "text": "what is artificial intelligence",
          "parameters": {}
        }
      ],
      "parameters": []
    },
    {
      "method_name": "_handle_continue_conversation",
      "intent_suffix": "general",
      "description": "Handle general conversation continuation and fallback",
      "phrases": [
        "continue",
        "let's continue",
        "what else",
        "go on"
      ],
      "lemmas": [],
      "token_patterns": [
        [
          {
            "TEXT": {
              "REGEX": "continue|go"
            }
          },
          {
            "TEXT": {
              "REGEX": "on|ahead"
            }
          }
        ],
        [
          {
            "TEXT": "what"
          },
          {
            "TEXT": "else"
          }
        ]
      ],
      "examples": [
        {
          "text": "continue",
          "parameters": {}
        }
      ],
      "parameters": []
    }
  ],
  "global_parameters": [
    {
      "name": "session_id",
      "description": "Conversation session identifier"
    }
  ]
}
