// Irene — configuration resolves in layers. Render:
//   dot -Tpng docs/images/config-layers.dot -o docs/images/config-layers.png
digraph layers {
  rankdir=LR; bgcolor="white"; splines=spline; nodesep=0.4; ranksep=0.85;
  fontname="Helvetica"; labelloc=t; fontsize=15;
  label="Configuration resolves in layers: defaults, then the TOML file, then the environment";
  node [fontname="Helvetica", fontsize=10, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#616161", arrowsize=0.7];

  defaults [label="Pydantic defaults\nevery field has one", fillcolor="#eeeeee", color="#9e9e9e"];
  file     [label="TOML config\nconfig.toml  or  -c <file>", fillcolor="#fff8e1", color="#f9a825"];
  env      [label="environment / .env\nIRENE_COMPONENTS__TTS=true\n( __ = nested section )", fillcolor="#e3f2fd", color="#1976d2"];
  validate [label="validate\ntypes + cross-field rules\n(e.g. TTS needs Audio)", fillcolor="#e3f2fd", color="#1976d2"];
  core     [label="CoreConfig\ntyped, validated", fillcolor="#e8f5e8", color="#388e3c"];

  defaults -> file [label="overridden by"];
  file     -> env  [label="overridden by"];
  env -> validate -> core;
}
