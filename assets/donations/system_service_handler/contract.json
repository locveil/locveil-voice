{
  "$schema": "../../donation_contract_v1.1.json",
  "schema_version": "1.1",
  "donation_version": "1.1.0",
  "handler_domain": "service",
  "intent_name_patterns": [
    "service.status",
    "service.stats",
    "service.health"
  ],
  "domain_patterns": [
    "service"
  ],
  "method_donations": [
    {
      "method_name": "_handle_service_status",
      "intent_suffix": "status",
      "boost": 1.4,
      "room_context": "none",
      "parameters": [
        {
          "name": "component",
          "type": "string",
          "required": false,
          "entity_type": "generic"
        }
      ]
    },
    {
      "method_name": "_handle_service_stats",
      "intent_suffix": "stats",
      "boost": 1.3,
      "room_context": "none",
      "parameters": [
        {
          "name": "metric_type",
          "type": "choice",
          "required": false,
          "choices": [
            "performance",
            "memory",
            "cpu",
            "network",
            "all"
          ],
          "entity_type": "generic"
        }
      ]
    },
    {
      "method_name": "_handle_service_health",
      "intent_suffix": "health",
      "boost": 1.2,
      "room_context": "none",
      "parameters": [
        {
          "name": "detailed",
          "type": "boolean",
          "required": false,
          "entity_type": "generic"
        }
      ]
    }
  ],
  "global_parameters": [
    {
      "name": "language",
      "type": "choice",
      "required": false,
      "choices": [
        "ru",
        "en"
      ],
      "entity_type": "generic"
    }
  ]
}
