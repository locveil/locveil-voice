// Irene — smart-home actuation (planned). Render:
//   dot -Tpng docs/images/mqtt-flow.dot -o docs/images/mqtt-flow.png
digraph mqtt {
  rankdir=LR; bgcolor="white"; splines=spline; nodesep=0.4; ranksep=0.85;
  fontname="Helvetica"; labelloc=t; fontsize=15;
  label="PLANNED — Irene recognises a device intent and speaks one canonical command; the bridge owns the hardware";
  node [fontname="Helvetica", fontsize=10, shape=box, style="filled,rounded", penwidth=1.4];
  edge [fontname="Helvetica", fontsize=9, color="#616161", arrowsize=0.7];

  utt     [label="“включи свет\nв гостиной”", fillcolor="#fff8e1", color="#f9a825", fontsize=11];
  nlu     [label="NLU\nresolve device · room ·\ncapability · value", fillcolor="#f3e5f5", color="#7b1fa2"];
  handler [label="device handler\n(donation-driven)", fillcolor="#e8f5e8", color="#388e3c"];
  cmd     [label="DeviceCommand\nref · capability · action · params\ncanonical, broker-blind", fillcolor="#fff8e1", color="#f9a825"];
  om      [label="OutputManager\nroute device_command\n→ the bridge output", fillcolor="#e3f2fd", color="#1976d2"];
  bridge  [label="wb-mqtt-bridge\ncanonical → native MQTT", fillcolor="#eeeeee", color="#616161", shape=box, style="filled"];
  device  [label="device\nlight · cover · climate", fillcolor="#f3e5f5", color="#7b1fa2"];

  utt -> nlu -> handler -> cmd -> om -> bridge -> device;

  catalog [label="DeviceCatalog\npulled from the bridge:\nrooms · devices · capabilities", fillcolor="#e3f2fd", color="#1976d2"];
  bridge  -> catalog [label="catalog pull (startup)", style=dashed, color="#9e9e9e", dir=back];
  catalog -> nlu     [label="real device / room\nentities", style=dashed, color="#1976d2", fontcolor="#1976d2"];

  bridge -> om [label="value echo → spoken confirm", style=dashed, color="#7b1fa2", fontcolor="#7b1fa2"];
}
