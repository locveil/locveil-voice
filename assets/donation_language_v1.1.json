{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "donation_language_v1.1.json",
  "title": "Irene Intent Donation — per-language phrasing (v1.1)",
  "description": "QUAL-29: the per-language phrasing for a handler donation. Joined to the language-neutral contract.json by method_name#intent_suffix and param name. Carries phrases/lemmas/patterns/examples + per-param description/extraction_patterns/aliases/default_value/choice_surfaces. NO ParameterSpec core (that lives once in contract.json).",
  "type": "object",
  "required": ["schema_version", "language", "method_donations"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": "1.1" },
    "handler_domain": { "type": "string" },
    "language": { "type": "string", "minLength": 2 },
    "description": { "type": "string" },
    "stop_command_patterns": { "type": "array", "items": { "type": "string" } },
    "action_patterns": { "type": "array", "items": { "type": "string" } },
    "additional_recognition_patterns": { "type": "array", "items": { "type": "string" } },
    "negative_patterns": { "type": "array" },
    "language_detection": { "type": "object" },
    "train_keywords": { "type": "array", "items": { "type": "string" } },
    "method_donations": {
      "type": "array",
      "items": { "$ref": "#/$defs/method" }
    },
    "global_parameters": {
      "type": "array",
      "items": { "$ref": "#/$defs/param" }
    }
  },
  "$defs": {
    "method": {
      "type": "object",
      "required": ["method_name", "intent_suffix"],
      "additionalProperties": false,
      "properties": {
        "method_name": { "type": "string" },
        "intent_suffix": { "type": "string" },
        "description": { "type": "string" },
        "phrases": { "type": "array", "items": { "type": "string" } },
        "lemmas": { "type": "array", "items": { "type": "string" } },
        "token_patterns": { "type": "array" },
        "slot_patterns": { "type": "object" },
        "examples": { "type": "array", "items": { "type": "object" } },
        "parameters": { "type": "array", "items": { "$ref": "#/$defs/param" } }
      }
    },
    "param": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "extraction_patterns": { "type": "array", "items": { "type": "object" } },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "default_value": {},
        "choice_surfaces": {
          "type": "object",
          "description": "{canonical token: [spoken surface forms in this language]}",
          "additionalProperties": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
